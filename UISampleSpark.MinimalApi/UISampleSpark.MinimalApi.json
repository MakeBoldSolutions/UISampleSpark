{
  "openapi": "3.1.1",
  "info": {
    "title": "UI Sample Spark API",
    "description": "Employee management API for the UI Sample Spark educational project.\n\nDemonstrates .NET 10 Minimal API patterns including rate limiting,\nAPI key authentication, and RFC 7807 ProblemDetails error responses.\n\n**Authentication:** Pass your API key in the `X-API-Key` request header.",
    "contact": {
      "name": "Mark Hazleton",
      "url": "https://markhazleton.com"
    },
    "version": "v1"
  },
  "paths": {
    "/employees": {
      "get": {
        "tags": [
          "Employees: Query"
        ],
        "summary": "List all employees",
        "description": "Returns the full list of employees using default paging.\n\nResults are sorted by employee ID. Use the departments endpoint\nto look up valid department values.",
        "operationId": "GetEmployees",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeList"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "Employees: Command"
        ],
        "summary": "Create a new employee",
        "description": "Creates a new employee record. The request body must include all required fields:\n`name`, `age` (minimum 18), `state`, `country`, and `department`.\n\nReturns **201 Created** with the saved employee wrapped in a response envelope.",
        "operationId": "CreateEmployee",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmployeeDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/employees/{id}": {
      "get": {
        "tags": [
          "Employees: Query"
        ],
        "summary": "Get employee by ID",
        "description": "Returns a single employee record matching the provided integer ID.",
        "operationId": "GetEmployeeById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/departments": {
      "get": {
        "tags": [
          "Departments: Query"
        ],
        "summary": "List all departments",
        "description": "Returns all departments defined in the system, excluding soft-deleted entries.",
        "operationId": "GetDepartments",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DepartmentDto"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DepartmentDto": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "employees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmployeeDto"
            }
          },
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "EmployeeDepartmentEnum": {
        "type": "integer"
      },
      "EmployeeDto": {
        "required": [
          "name",
          "state"
        ],
        "type": "object",
        "properties": {
          "age": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "country": {
            "type": [
              "null",
              "string"
            ]
          },
          "department": {
            "$ref": "#/components/schemas/EmployeeDepartmentEnum"
          },
          "departmentName": {
            "type": [
              "null",
              "string"
            ]
          },
          "gender": {
            "$ref": "#/components/schemas/GenderEnum"
          },
          "genderName": {
            "type": [
              "null",
              "string"
            ]
          },
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "manager_id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          },
          "state": {
            "type": [
              "null",
              "string"
            ]
          },
          "profile_picture": {
            "type": [
              "null",
              "string"
            ]
          },
          "profileImage": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/IFormFile"
              }
            ]
          }
        }
      },
      "EmployeeList": {
        "type": "object",
        "properties": {
          "list": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "$ref": "#/components/schemas/EmployeeDto"
            }
          }
        }
      },
      "EmployeeResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "resource": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/EmployeeDto"
              }
            ]
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "GenderEnum": {
        "type": "integer"
      },
      "IFormFile": {
        "type": [
          "null",
          "string"
        ],
        "format": "binary"
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Employees: Query"
    },
    {
      "name": "Employees: Command"
    },
    {
      "name": "Departments: Query"
    }
  ]
}
{
  "openapi": "3.1.1",
  "info": {
    "title": "UI Sample Spark API",
    "description": "Employee management API for the UI Sample Spark educational project.\r\n\r\nDemonstrates ASP.NET Core MVC, Razor Pages, Blazor, React, Vue, and htmx\r\nalongside rate limiting, API key authentication, and RFC 7807 error responses.\r\n\r\n**Authentication:** Pass your API key in the `X-API-Key` request header.",
    "contact": {
      "name": "Mark Hazleton",
      "url": "https://markhazleton.com"
    },
    "version": "v1"
  },
  "paths": {
    "/api-test-spark/config": {
      "get": {
        "tags": [
          "UISampleSpark.UI"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/status": {
      "get": {
        "tags": [
          "Status"
        ],
        "operationId": "GetStatus",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplicationStatus"
                }
              }
            }
          }
        }
      }
    },
    "/status/explorer": {
      "get": {
        "tags": [
          "Status"
        ],
        "operationId": "GetApiExplorer",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApplicationStatus": {
        "type": "object",
        "properties": {
          "buildDate": {
            "type": "string",
            "format": "date-time"
          },
          "buildVersion": {
            "$ref": "#/components/schemas/BuildVersion"
          },
          "features": {
            "type": [
              "null",
              "object"
            ],
            "additionalProperties": {
              "type": "string"
            }
          },
          "messages": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "region": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/ServiceStatus"
          },
          "tests": {
            "type": [
              "null",
              "object"
            ],
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "BuildVersion": {
        "type": "object",
        "properties": {
          "build": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "majorVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "minorVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "revision": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "ServiceStatus": {
        "type": "integer",
        "default": 2
      }
    }
  },
  "tags": [
    {
      "name": "UISampleSpark.UI"
    },
    {
      "name": "Status"
    }
  ]
}
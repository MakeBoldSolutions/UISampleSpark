{
  "openapi": "3.1.1",
  "info": {
    "title": "UI Sample Spark API",
    "description": "Employee management API for the UI Sample Spark educational project.\r\n\r\nDemonstrates ASP.NET Core MVC, Razor Pages, Blazor, React, Vue, and htmx\r\nalongside rate limiting, API key authentication, and RFC 7807 error responses.\r\n\r\n**Authentication:** Pass your API key in the `X-API-Key` request header.",
    "contact": {
      "name": "Mark Hazleton",
      "url": "https://markhazleton.com"
    },
    "version": "v1"
  },
  "paths": {
    "/api-test-spark/config": {
      "get": {
        "tags": [
          "UISampleSpark.UI"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/status/explorer": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Returns Current Application Status",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ApiExplorerModel"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/status": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Returns Current Application Status",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplicationStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/department": {
      "get": {
        "tags": [
          "DepartmentApi"
        ],
        "summary": "Returns collection of all departments",
        "parameters": [
          {
            "name": "includeEmployees",
            "in": "query",
            "description": "Whether to include employees in the response",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection of departments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DepartmentDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/department/{id}": {
      "get": {
        "tags": [
          "DepartmentApi"
        ],
        "summary": "Returns a single department by identifier",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Department identifier",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepartmentDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResource"
                }
              }
            }
          }
        }
      }
    },
    "/api/employee/{id}": {
      "delete": {
        "tags": [
          "EmployeeApi"
        ],
        "summary": "Deletes an employee by their unique identifier.",
        "description": "Removes the employee record from the database. This operation cannot be undone.\r\nExample: DELETE /api/employee/1",
        "operationId": "DeleteEmployee",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The unique identifier of the employee to delete.",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Employee successfully deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeDto"
                }
              }
            }
          },
          "400": {
            "description": "Employee not found or could not be deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResource"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "EmployeeApi"
        ],
        "summary": "Retrieves a single employee by their unique identifier.",
        "description": "Returns the complete employee record including department information.\r\nExample: GET /api/employee/1",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The unique identifier of the employee to retrieve.",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Employee found and returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeDto"
                }
              }
            }
          },
          "400": {
            "description": "Employee with specified ID not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResource"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "EmployeeApi"
        ],
        "summary": "Updates an existing employee according to an identifier.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Employee identifier.",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "description": "Cancellation token",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmployeeDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EmployeeDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EmployeeDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResource"
                }
              }
            }
          }
        }
      }
    },
    "/api/employee": {
      "get": {
        "tags": [
          "EmployeeApi"
        ],
        "summary": "Returns collection of all employees",
        "parameters": [
          {
            "name": "PageNumber",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          },
          {
            "name": "PageSize",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection of employees",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EmployeeDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "EmployeeApi"
        ],
        "summary": "Creates a new employee.",
        "requestBody": {
          "description": "Cancellation token",
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "$ref": "#/components/schemas/EmployeeDto"
                  }
                ]
              }
            },
            "text/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "$ref": "#/components/schemas/EmployeeDto"
                  }
                ]
              }
            },
            "application/*+json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "$ref": "#/components/schemas/EmployeeDto"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResource"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiDescriptionModel": {
        "type": "object",
        "properties": {
          "relativePath": {
            "type": "string"
          }
        },
        "description": ""
      },
      "ApiExplorerModel": {
        "type": "object",
        "properties": {
          "groupItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiDescriptionModel"
            }
          },
          "groupName": {
            "type": "string"
          }
        },
        "description": ""
      },
      "ApplicationStatus": {
        "type": "object",
        "properties": {
          "buildDate": {
            "type": "string",
            "format": "date-time"
          },
          "buildVersion": {
            "$ref": "#/components/schemas/BuildVersion"
          },
          "features": {
            "type": [
              "null",
              "object"
            ],
            "additionalProperties": {
              "type": "string"
            }
          },
          "messages": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "region": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/ServiceStatus"
          },
          "tests": {
            "type": [
              "null",
              "object"
            ],
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "BuildVersion": {
        "type": "object",
        "properties": {
          "build": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "majorVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "minorVersion": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "revision": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "DepartmentDto": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "employees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmployeeDto"
            }
          },
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "EmployeeDepartmentEnum": {
        "type": "integer"
      },
      "EmployeeDto": {
        "required": [
          "name",
          "state"
        ],
        "type": "object",
        "properties": {
          "age": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "country": {
            "type": [
              "null",
              "string"
            ]
          },
          "department": {
            "$ref": "#/components/schemas/EmployeeDepartmentEnum"
          },
          "departmentName": {
            "type": [
              "null",
              "string"
            ]
          },
          "gender": {
            "$ref": "#/components/schemas/GenderEnum"
          },
          "genderName": {
            "type": [
              "null",
              "string"
            ]
          },
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "manager_id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "name": {
            "type": [
              "null",
              "string"
            ]
          },
          "state": {
            "type": [
              "null",
              "string"
            ]
          },
          "profile_picture": {
            "type": [
              "null",
              "string"
            ]
          },
          "profileImage": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/IFormFile"
              }
            ]
          }
        }
      },
      "ErrorResource": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Messages"
          },
          "success": {
            "type": "boolean",
            "description": "Success"
          }
        },
        "description": "Error Resource"
      },
      "GenderEnum": {
        "type": "integer"
      },
      "IFormFile": {
        "type": [
          "null",
          "string"
        ],
        "format": "binary"
      },
      "ServiceStatus": {
        "type": "integer",
        "default": 2
      }
    }
  },
  "tags": [
    {
      "name": "UISampleSpark.UI"
    },
    {
      "name": "Status"
    },
    {
      "name": "DepartmentApi"
    },
    {
      "name": "EmployeeApi"
    }
  ]
}